#!/bin/sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

echo "pre-commit: running staged agent-surface guard"
npm run --if-present check:agent-surface:staged

echo "pre-commit: checking private runtime files"
npm run --if-present check:private-runtime

echo "pre-commit: checking public boundary markers"
npm run --if-present check:public-boundary
