{
  "name": "ai-quality-loops",
  "version": "1.1.0",
  "description": "Core LLM-driven review and visual quality control tools.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Stefan Henß",
  "license": "MIT",
  "homepage": "https://github.com/henss/ai-quality-loops#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henss/ai-quality-loops.git"
  },
  "keywords": [
    "ai",
    "llm",
    "ollama",
    "quality-control",
    "review",
    "vision",
    "screenshot"
  ],
  "files": [
    "dist",
    "docs",
    "examples",
    "schemas",
    "personas",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "batch-review-compare": "dist/cli/batch-review-compare.js",
    "batch-review": "dist/cli/batch-review.js",
    "expert-review": "dist/cli/expert-review.js",
    "review-compare": "dist/cli/review-compare.js",
    "reviewer-calibration-benchmark": "dist/cli/reviewer-calibration-benchmark.js",
    "review-focus-lint": "dist/cli/review-focus-lint.js",
    "review-gate": "dist/cli/review-gate.js",
    "review-preflight": "dist/cli/review-preflight.js",
    "vision-preview": "dist/cli/vision-preview.js",
    "vision-review": "dist/cli/vision-review.js",
    "vision-sections": "dist/cli/vision-sections.js",
    "web-screenshot": "dist/cli/screenshot.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify:session": "pnpm typecheck && pnpm test && pnpm check:agent-surface",
    "git-hooks:install": "powershell -ExecutionPolicy Bypass -File .\\scripts\\install-git-hooks.ps1",
    "check:agent-surface": "tsx scripts/check-agent-surface.ts",
    "check:agent-surface:staged": "tsx scripts/check-agent-surface.ts --staged",
    "refactor:extract-exports": "tsx scripts/refactor-extract-exports.ts",
    "check:agent-surface:preedit": "tsx scripts/check-agent-surface.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:typechecked": "eslint . --config eslint.typechecked.config.mjs",
    "arch": "depcruise . --exclude \"(^|/)(dist|build|coverage|.runtime|.sandbox-tmp)/\" --config .dependency-cruiser.cjs --ignore-known .dependency-cruiser-known-violations.json --output-type err",
    "arch:baseline": "depcruise . --exclude \"(^|/)(dist|build|coverage|.runtime|.sandbox-tmp)/\" --config .dependency-cruiser.cjs --output-type baseline --output-to .dependency-cruiser-known-violations.json",
    "arch:graph": "depcruise . --exclude \"(^|/)(dist|build|coverage|.runtime|.sandbox-tmp)/\" --config .dependency-cruiser.cjs --ignore-known .dependency-cruiser-known-violations.json --output-type mermaid",
    "lint:docs": "node -e \"const cp=require('node:child_process'),p=require('node:path'),fs=require('node:fs');const roots=[process.env.LLM_ORCHESTRATOR_ROOT,p.resolve(process.cwd(),'..','llm-orchestrator'),'D:/workspace/llm-orchestrator'].filter(Boolean);const root=roots.find((r)=>fs.existsSync(p.join(r,'package.json')));if(!root)throw new Error('Set LLM_ORCHESTRATOR_ROOT to the llm-orchestrator repo');const result=cp.spawnSync('pnpm',['--dir',root,'orch','docs:lint','--','--repo-root',process.cwd()],{stdio:'inherit',shell:process.platform==='win32'});process.exit(result.status??1)\""
  },
  "dependencies": {
    "cac": "^7.0.0",
    "dotenv": "^17.3.1",
    "execa": "^9.6.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "typescript": "^5.6.3",
    "vitest": "^1.6.1",
    "eslint": "^10.2.0",
    "ts-morph": "^27.0.2",
    "tsx": "4.21.0",
    "@eslint/js": "^10.0.1",
    "globals": "^16.5.0",
    "typescript-eslint": "^8.50.0",
    "dependency-cruiser": "^17.3.10"
  }
}
