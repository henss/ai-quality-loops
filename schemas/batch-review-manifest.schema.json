{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/henss/ai-quality-loops/schemas/batch-review-manifest.schema.json",
  "title": "Batch Review Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["reviews"],
  "properties": {
    "defaults": {
      "$ref": "#/$defs/manifestOptions"
    },
    "reviews": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/manifestEntry"
      }
    }
  },
  "$defs": {
    "batchReviewMode": {
      "type": "string",
      "enum": ["expert", "vision"]
    },
    "manifestOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "$ref": "#/$defs/batchReviewMode"
        },
        "expert": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "outputDir": {
          "type": "string",
          "minLength": 1
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "css": {
          "type": "string",
          "minLength": 1
        },
        "promptLibraryPath": {
          "type": "string",
          "minLength": 1
        },
        "contextPath": {
          "type": "string",
          "minLength": 1
        },
        "ollamaUrl": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "manifestEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "outputPath": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "$ref": "#/$defs/batchReviewMode"
        },
        "expert": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "outputDir": {
          "type": "string",
          "minLength": 1
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "css": {
          "type": "string",
          "minLength": 1
        },
        "promptLibraryPath": {
          "type": "string",
          "minLength": 1
        },
        "contextPath": {
          "type": "string",
          "minLength": 1
        },
        "ollamaUrl": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
