{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/henss/ai-quality-loops/schemas/batch-review-summary.schema.json",
  "title": "Batch Review Summary",
  "type": "object",
  "additionalProperties": false,
  "required": ["total", "succeeded", "failed", "results"],
  "properties": {
    "manifestPath": {
      "type": "string",
      "minLength": 1
    },
    "total": {
      "type": "integer",
      "minimum": 0
    },
    "succeeded": {
      "type": "integer",
      "minimum": 0
    },
    "failed": {
      "type": "integer",
      "minimum": 0
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "mode", "targetSummary", "status"],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 0
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "resultKey": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "type": "string",
            "enum": ["expert", "vision"]
          },
          "targetSummary": {
            "type": "string",
            "minLength": 1
          },
          "outputPath": {
            "type": "string",
            "minLength": 1
          },
          "structuredOutputPath": {
            "type": "string",
            "minLength": 1
          },
          "structuredResult": {
            "type": "object",
            "additionalProperties": false,
            "required": ["overallSeverity", "totalFindings", "findingCounts"],
            "properties": {
              "overallSeverity": {
                "type": "string",
                "enum": ["critical", "high", "medium", "low", "unknown"]
              },
              "totalFindings": {
                "type": "integer",
                "minimum": 0
              },
              "findingCounts": {
                "type": "object",
                "additionalProperties": false,
                "required": ["critical", "high", "medium", "low", "unknown"],
                "properties": {
                  "critical": { "type": "integer", "minimum": 0 },
                  "high": { "type": "integer", "minimum": 0 },
                  "medium": { "type": "integer", "minimum": 0 },
                  "low": { "type": "integer", "minimum": 0 },
                  "unknown": { "type": "integer", "minimum": 0 }
                }
              },
              "decision": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "verdict",
                  "confidence",
                  "acceptedFindings",
                  "rejectedFindings"
                ],
                "properties": {
                  "verdict": {
                    "type": "string",
                    "enum": [
                      "accept",
                      "accept_with_follow_up",
                      "changes_requested",
                      "blocked",
                      "process_failed"
                    ]
                  },
                  "confidence": {
                    "type": "string",
                    "enum": ["low", "medium", "high"]
                  },
                  "acceptedFindings": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "rejectedFindings": {
                    "type": "integer",
                    "minimum": 0
                  }
                }
              }
            }
          },
          "status": {
            "type": "string",
            "enum": ["success", "failure"]
          },
          "errorSummary": {
            "type": "string",
            "minLength": 1
          },
          "durationMs": {
            "type": "integer",
            "minimum": 0
          },
          "outputChars": {
            "type": "integer",
            "minimum": 0
          },
          "decisionParsed": {
            "type": "boolean"
          },
          "ollamaTelemetry": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "totalDurationMs": { "type": "number", "minimum": 0 },
              "loadDurationMs": { "type": "number", "minimum": 0 },
              "promptEvalCount": { "type": "number", "minimum": 0 },
              "promptEvalDurationMs": { "type": "number", "minimum": 0 },
              "evalCount": { "type": "number", "minimum": 0 },
              "evalDurationMs": { "type": "number", "minimum": 0 }
            }
          }
        }
      }
    }
  }
}
