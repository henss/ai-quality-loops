{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/henss/ai-quality-loops/schemas/batch-review-summary.schema.json",
  "title": "Batch Review Summary",
  "type": "object",
  "additionalProperties": false,
  "required": ["total", "succeeded", "failed", "results"],
  "properties": {
    "manifestPath": {
      "type": "string",
      "minLength": 1
    },
    "total": {
      "type": "integer",
      "minimum": 0
    },
    "succeeded": {
      "type": "integer",
      "minimum": 0
    },
    "failed": {
      "type": "integer",
      "minimum": 0
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "mode", "targetSummary", "status"],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 0
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "type": "string",
            "enum": ["expert", "vision"]
          },
          "targetSummary": {
            "type": "string",
            "minLength": 1
          },
          "outputPath": {
            "type": "string",
            "minLength": 1
          },
          "structuredOutputPath": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["success", "failure"]
          },
          "errorSummary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
