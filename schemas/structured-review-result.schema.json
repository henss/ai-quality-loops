{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/henss/ai-quality-loops/schemas/structured-review-result.schema.json",
  "title": "Structured Review Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "workflow",
    "expert",
    "model",
    "summary",
    "overallSeverity",
    "findings",
    "provenance",
    "markdown"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1"
    },
    "workflow": {
      "type": "string",
      "enum": ["expert", "vision"]
    },
    "expert": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "overallSeverity": {
      "$ref": "#/$defs/severity"
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "verdict",
        "confidence",
        "blocking",
        "max_severity",
        "summary",
        "blocking_findings",
        "non_blocking_findings",
        "required_before_merge",
        "follow_up"
      ],
      "properties": {
        "schema": {
          "const": "peer_review_decision_v1"
        },
        "verdict": {
          "type": "string",
          "enum": [
            "accept",
            "accept_with_follow_up",
            "abstain_request_evidence",
            "changes_requested",
            "blocked",
            "process_failed"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "blocking": {
          "type": "boolean"
        },
        "max_severity": {
          "$ref": "#/$defs/severity"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "blocking_findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          }
        },
        "non_blocking_findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          }
        },
        "required_before_merge": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "follow_up": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_step_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "revise_artifact",
              "collect_more_evidence",
              "request_evidence",
              "rerun_review",
              "request_caller_review",
              "track_follow_up"
            ]
          }
        },
        "evidence_requests": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceRequest"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["verdict"],
            "properties": {
              "verdict": {
                "const": "abstain_request_evidence"
              }
            }
          },
          "then": {
            "required": ["evidence_requests"],
            "properties": {
              "evidence_requests": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "provenance": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "value"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "string",
            "minLength": 1
          },
          "freshness": {
            "type": "object",
            "additionalProperties": false,
            "required": ["signal"],
            "properties": {
              "signal": {
                "type": "string",
                "enum": [
                  "live_refresh",
                  "mirrored_current_state",
                  "historical_context"
                ]
              },
              "asOf": {
                "type": "string",
                "minLength": 1
              },
              "note": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "authority": {
            "type": "object",
            "additionalProperties": false,
            "required": ["signal"],
            "properties": {
              "signal": {
                "type": "string",
                "enum": [
                  "source_of_truth",
                  "derived_summary",
                  "advisory_boundary"
                ]
              },
              "note": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "markdown": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low", "unknown"]
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "summary", "severity"],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "recommendation": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidenceRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "needed_evidence"],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "needed_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
