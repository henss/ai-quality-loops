{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/henss/ai-quality-loops/schemas/structured-review-result.schema.json",
  "title": "Structured Review Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "workflow",
    "expert",
    "model",
    "summary",
    "overallSeverity",
    "findings",
    "provenance",
    "markdown"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1"
    },
    "workflow": {
      "type": "string",
      "enum": ["expert", "vision"]
    },
    "expert": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "overallSeverity": {
      "$ref": "#/$defs/severity"
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "verdict",
        "confidence",
        "blocking",
        "max_severity",
        "summary",
        "blocking_findings",
        "non_blocking_findings",
        "required_before_merge",
        "follow_up"
      ],
      "properties": {
        "schema": {
          "const": "peer_review_decision_v1"
        },
        "verdict": {
          "type": "string",
          "enum": [
            "accept",
            "accept_with_follow_up",
            "changes_requested",
            "blocked",
            "process_failed"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "blocking": {
          "type": "boolean"
        },
        "max_severity": {
          "$ref": "#/$defs/severity"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "blocking_findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          }
        },
        "non_blocking_findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          }
        },
        "required_before_merge": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "follow_up": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "provenance": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "value"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "markdown": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low", "unknown"]
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "summary", "severity"],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "recommendation": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
